ninja_required_version = 1.3
cxx = c++

cflags = -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -fPIC -I/home/y00889327/AscendOpGenAgent/cmhc/binding -I/usr/local/python3.11.10/lib/python3.11/site-packages/torch/include -I/usr/local/python3.11.10/lib/python3.11/site-packages/torch/include/torch/csrc/api/include -I/usr/local/python3.11.10/include/python3.11 -c
post_cflags = -std=c++17 -O2 -fPIC -DTORCH_API_INCLUDE_EXTENSION_H -DTORCH_EXTENSION_NAME=cmhc_torch_ops
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc







